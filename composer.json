{
    "name": "provisionesta/audit",
    "description": "Audit and Event Log Handler for Laravel",
    "homepage": "https://gitlab.com/provisionesta/audit",
    "license": "MIT",
    "authors": [
        {
            "name": "Jefferson Martin",
            "email": "provisionesta@jeffersonmartin.com"
        }
    ],
    "require": {
        "php": "^8.0 || ^8.1 || ^8.2 || ^8.3",
        "illuminate/config": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "illuminate/log": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "illuminate/support": "^8.0 || ^9.0 || ^10.0 || ^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.23 || ^7.0 || ^8.0",
        "larastan/larastan": "^2.7"
    },
    "autoload": {
        "psr-4": {
            "Provisionesta\\Audit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Provisionesta\\Audit\\AuditServiceProvider"
            ]
        }
    }
}

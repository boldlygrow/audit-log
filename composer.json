{
    "name": "boldlygrow/audit-log",
    "description": "Audit and Event Log Handler for Laravel",
    "homepage": "https://github.com/boldlygrow/audit-log",
    "license": "MIT",
    "authors": [
        {
            "name": "Jeff Martin",
            "email": "jeff@boldlygrow.us"
        }
    ],
    "replace": {
        "provisionesta/audit": "self.version"
    },
    "require": {
        "php": "^8.0",
        "illuminate/config": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
        "illuminate/log": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.23 || ^7.0 || ^8.0 || ^9.0 || ^10.0",
        "larastan/larastan": "^2.7 || ^3.0"
    },
    "autoload": {
        "psr-4": {
            "BoldlyGrow\\AuditLog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BoldlyGrow\\AuditLog\\AuditLogServiceProvider"
            ]
        }
    }
}
